# Drpexoticfarms™ web — environment

# Public WhatsApp (digits only, country code included, no +)
VITE_WHATSAPP_PHONE=919876543210

# Optional: full Google Maps embed URL (iframe src). Replace with your verified embed from Google Maps → Share → Embed.
VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3684.0!2d75.8577!3d22.7196!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjLCsDQzJzEwLjYiTiA3NcKwNTEnMjcuNyJF!5e0!3m2!1sen!2sin!4v1

# Optional: POST endpoint for contact form (JSON). If unset, form opens mailto fallback.
# VITE_CONTACT_FORM_ENDPOINT=https://api.example.com/contact

# Optional: newsletter provider endpoint (POST JSON { email, consent }).
# VITE_NEWSLETTER_ENDPOINT=

# Optional: Instagram Graph API access token for homepage reels.
# VITE_INSTAGRAM_ACCESS_TOKEN=

# Admin UI gate (browser session). Change before production.
VITE_ADMIN_PASSWORD=drp-admin-change-me
